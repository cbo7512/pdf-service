# ═══════════════════════════════════════════════════
#  DocFlow — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════

# PostgreSQL
POSTGRES_DB=docflow
POSTGRES_USER=docflow
POSTGRES_PASSWORD=DocFlow2025!   # Change this!

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-64char-string

# App timezone
TZ=Europe/Istanbul

# Frontend port (Portainer: forward this to your domain)
FRONTEND_PORT=3331
